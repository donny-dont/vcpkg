{
  "name": "lcms",
  "version": "2.16",
  "description": "Little CMS.",
  "homepage": "https://github.com/mm2/Little-CMS",
  "license": "MIT",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "fastfloat": {
      "description": "Build and install the fast float plugin, use only if GPL 3.0 is acceptable"
    },
    "jpeg": {
      "description": "Use JPEG",
      "dependencies": [
        "libjpeg-turbo"
      ]
    },
    "threaded": {
      "description": "Build and install the multi threaded plugin, use only if GPL 3.0 is acceptable"
    },
    "tiff": {
      "description": "Use TIFF",
      "dependencies": [
        "tiff"
      ]
    },
    "tools": {
      "description": "Build the utilities"
    }
  }
}
